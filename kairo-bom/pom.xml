            </dependency>
            <dependency>
                <groupId>io.kairo</groupId>
                <artifactId>kairo-core</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>io.kairo</groupId>
                <artifactId>kairo-tools</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>io.kairo</groupId>
                <artifactId>kairo-mcp</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>io.kairo</groupId>
                <artifactId>kairo-multi-agent</artifactId>
                <version>${revision}</version>
            </dependency>
            <dependency>
                <groupId>io.kairo</groupId>
                <artifactId>kairo-observability</artifactId>
                <version>${revision}</version>
