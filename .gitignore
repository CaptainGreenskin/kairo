.flattened-pom.xml

# Java
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# IDE - IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# IDE - Eclipse
.classpath
.project
.settings/
bin/
# …but test fixtures legitimately ship a bin/ component dir (e.g. plugin loader fixtures);
# the blanket bin/ rule above was silently excluding them, so they were absent on CI.
!**/src/test/resources/**/bin/
!**/src/test/resources/**/bin/**

# IDE - VS Code
.vscode/

# Environment & Secrets
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Internal docs (not for public release)
docs/ROADMAP.md
docs/KV-CACHE-PROPOSAL.md
.plans/

# Local scripts (not for public release)
scripts/

# Kairo runtime
/tmp/kairo-sessions/
.kairo/
# kairo-code & opencode worktree checkouts (8MB+ of full-repo clones agents
# leave behind in long debug sessions — never source of truth)
.kairo-code/worktrees/

# VitePress docs
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/
dependency-tree.txt

# cli-dispatcher (transient — lives outside the repo, never commit)
.dispatcher/

# dispatch task management (briefs, evals, queue — lives outside the repo)
tasks/

# local Claude Code config / dispatch commands
.claude/

# Playwright MCP snapshots
.playwright-mcp/
