# Kairo Environment Configuration
# Copy this file to .env and fill in your values.

# === Model Provider API Keys ===
# At least one provider key is required.

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GLM (智谱清言) — https://open.bigmodel.cn/
GLM_API_KEY=

# Qwen (通义千问) — https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# === Optional Configuration ===

# Default model to use (e.g., claude-sonnet-4-20250514, glm-4-flash, qwen-turbo)
# KAIRO_DEFAULT_MODEL=

# GLM provider overrides
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-plus

# Qwen provider overrides
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# Session storage directory (default: ./tmp/kairo-sessions/)
# KAIRO_SESSION_DIR=

# Log level (default: INFO)
# KAIRO_LOG_LEVEL=INFO
