{
  "$schema": "https://github.com/liulihan/cli-dispatcher/schema/v0/dispatcher-config.json",
  "worktreeBase": ".dispatcher/worktrees",
  "branchPrefix": "feature",
  "verifyScript": ".dispatcher/verify.sh",
  "briefPrefixFile": ".dispatcher/brief-prefix.md",
  "logsDir": ".dispatcher/logs",
  "evalDir": "tasks/eval",
  "queueDir": "tasks/queue",
  "archiveDir": "tasks/_archive",
  "pathReviewThreshold": 20,
  "executors": {
    "qodercli": {
      "modelLevel": "qwork-ultimate"
    },
    "opencode": {},
    "aider": {}
  }
}
